/* ====================================================
   B. クイズエンジン制御プログラム (APP LOGIC)
   ==================================================== */
document.addEventListener('DOMContentLoaded', () => {

    const STATE = {
        theme: 'dark',
        view: 'dashboardView',
        quizMode: 'quick',
        categoryFilter: 'all',
        timerEnabled: true,
        
        questions: [],
        currentQuestionIndex: 0,
        selectedOptionIndex: null,
        score: 0,
        correctCount: 0,
        history: [],

        stats: {
            highScore: 0,
            attempts: 0,
            totalCorrect: 0,
            totalAnswered: 0
        },

        timer: {
            id: null,
            duration: 20000,
            timeLeft: 20000,
            interval: 100
        }
    };

    initTheme();
    loadStats();
    renderCategoryFilters();
    setupDashboardEvents();
    setupQuizEvents();
    setupKeyboardSupport();

    function initTheme() {
        const themeToggleBtn = document.getElementById('themeToggleBtn');
        const savedTheme = localStorage.getItem('theme') || 'dark';
        STATE.theme = savedTheme;
        document.documentElement.setAttribute('data-theme', savedTheme);
        
        themeToggleBtn.addEventListener('click', () => {
            const nextTheme = STATE.theme === 'dark' ? 'light' : 'dark';
            STATE.theme = nextTheme;
            document.documentElement.setAttribute('data-theme', nextTheme);
            localStorage.setItem('theme', nextTheme);
        });
    }

    function loadStats() {
        const savedStats = localStorage.getItem('civics_quiz_stats');
        if (savedStats) {
            try { STATE.stats = JSON.parse(savedStats); } catch(e) {}
        }
        updateStatsDashboard();
    }

    function updateStatsDashboard() {
        document.getElementById('statsHighScore').innerText = STATE.stats.highScore;
        document.getElementById('statsAttempts').innerText = STATE.stats.attempts;
        let accuracy = 0;
        if (STATE.stats.totalAnswered > 0) {
            accuracy = Math.round((STATE.stats.totalCorrect / STATE.stats.totalAnswered) * 100);
        }
        document.getElementById('statsAccuracy').innerText = accuracy;
    }

    function saveStats() {
        localStorage.setItem('civics_quiz_stats', JSON.stringify(STATE.stats));
        updateStatsDashboard();
    }

    function resetStats() {
        if (confirm("これまでの学習記録とハイスコアをすべてリセットしますか？")) {
            STATE.stats = { highScore: 0, attempts: 0, totalCorrect: 0, totalAnswered: 0 };
            saveStats();
        }
    }

    function renderCategoryFilters() {
        const container = document.getElementById('categoryFilterContainer');
        if (!container) return;

        const categories = new Set();
        CIVICS_QUIZ_DATA.forEach(q => {
            if (q.category) categories.add(q.category);
        });

        const allPill = container.querySelector('[data-category="all"]');
        container.innerHTML = '';
        container.appendChild(allPill);

        categories.forEach(cat => {
            const pill = document.createElement('button');
            pill.className = 'cat-pill';
            pill.setAttribute('data-category', cat);
            pill.innerText = cat;
            pill.addEventListener('click', () => {
                const pills = container.querySelectorAll('.cat-pill');
                pills.forEach(p => p.classList.remove('active'));
                pill.classList.add('active');
                STATE.categoryFilter = cat;
            });
            container.appendChild(pill);
        });

        allPill.addEventListener('click', () => {
            const pills = container.querySelectorAll('.cat-pill');
            pills.forEach(p => p.classList.remove('active'));
            allPill.classList.add('active');
            STATE.categoryFilter = 'all';
        });
    }

    function switchView(targetViewId) {
        STATE.view = targetViewId;
        const panels = document.querySelectorAll('.view-panel');
        panels.forEach(p => {
            if (p.id === targetViewId) p.classList.add('active-view');
            else p.classList.remove('active-view');
        });
        window.scrollTo(0, 0);
    }

    function setupDashboardEvents() {
        const modeBtns = document.querySelectorAll('.mode-btn');
        modeBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                modeBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                STATE.quizMode = btn.getAttribute('data-mode');
            });
        });

        const timerToggle = document.getElementById('timerToggleCheckbox');
        timerToggle.addEventListener('change', (e) => {
            STATE.timerEnabled = e.target.checked;
        });

        document.getElementById('btnResetStats').addEventListener('click', resetStats);
        document.getElementById('btnStartQuiz').addEventListener('click', startQuizSession);
    }

    function startQuizSession() {
        let pool = [...CIVICS_QUIZ_DATA];
        if (STATE.categoryFilter !== 'all') {
            pool = pool.filter(q => q.category === STATE.categoryFilter);
        }

        if (pool.length === 0) {
            alert(`選択された分野の問題がありません。`);
            return;
        }

        for (let i = pool.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [pool[i], pool[j]] = [pool[j], pool[i]];
        }

        if (STATE.quizMode === 'quick') {
            STATE.questions = pool.slice(0, 5);
        } else {
            STATE.questions = pool;
        }

        STATE.currentQuestionIndex = 0;
        STATE.score = 0;
        STATE.correctCount = 0;
        STATE.history = [];

        switchView('quizPlayView');
        renderCurrentQuestion();
    }

    function renderCurrentQuestion() {
        const qIndex = STATE.currentQuestionIndex;
        const total = STATE.questions.length;
        const q = STATE.questions[qIndex];
        STATE.selectedOptionIndex = null;

        document.getElementById('playCategoryBadge').innerText = q.category;
        document.getElementById('playCurrentIndex').innerText = qIndex + 1;
        document.getElementById('playTotalCount').innerText = total;
        document.getElementById('playQuestionText').innerText = q.question;

        const optionBtns = document.querySelectorAll('.play-option-btn');
        optionBtns.forEach((btn, idx) => {
            btn.classList.remove('correct-state', 'incorrect-state');
            btn.querySelector('.option-content').innerText = q.options[idx];
            btn.querySelector('.option-num').innerText = idx + 1;
        });

        if (STATE.timerEnabled) {
            document.getElementById('timerBarContainer').classList.remove('hidden');
            startTimer();
        } else {
            document.getElementById('timerBarContainer').classList.add('hidden');
        }
    }

    function selectOption(selectedIdx) {
        if (STATE.selectedOptionIndex !== null) return;
        stopTimer();

        STATE.selectedOptionIndex = selectedIdx;
        const qIndex = STATE.currentQuestionIndex;
        const q = STATE.questions[qIndex];
        const isCorrect = selectedIdx === q.answer;

        const optionBtns = document.querySelectorAll('.play-option-btn');
        optionBtns.forEach((btn, idx) => {
            if (idx === q.answer) btn.classList.add('correct-state');
            else if (idx === selectedIdx && !isCorrect) btn.classList.add('incorrect-state');
        });

        if (isCorrect) {
            STATE.correctCount++;
            const ptsPerQuestion = Math.round(100 / STATE.questions.length);
            STATE.score += ptsPerQuestion;
        }

        STATE.history.push({
            questionObj: q,
            userSelection: selectedIdx,
            isTimeout: false,
            isCorrect: isCorrect
        });

        setTimeout(() => { showFeedbackScreen(isCorrect, false); }, 800);
    }

    function handleTimeout() {
        STATE.selectedOptionIndex = -1;
        const qIndex = STATE.currentQuestionIndex;
        const q = STATE.questions[qIndex];

        const optionBtns = document.querySelectorAll('.play-option-btn');
        optionBtns.forEach((btn, idx) => {
            if (idx === q.answer) btn.classList.add('correct-state');
        });

        STATE.history.push({
            questionObj: q,
            userSelection: -1,
            isTimeout: true,
            isCorrect: false
        });

        setTimeout(() => { showFeedbackScreen(false, true); }, 800);
    }

    function showFeedbackScreen(isCorrect, isTimeout) {
        switchView('quizFeedbackView');

        const symbol = document.getElementById('feedbackSymbol');
        const titleText = document.getElementById('feedbackTitleText');
        const q = STATE.questions[STATE.currentQuestionIndex];

        if (isTimeout) {
            symbol.innerText = "⏳";
            titleText.innerText = "時間切れ...";
            titleText.style.color = "var(--color-timeout)";
        } else if (isCorrect) {
            symbol.innerText = "⭕";
            titleText.innerText = "正解！";
            titleText.style.color = "var(--color-correct)";
        } else {
            symbol.innerText = "❌";
            titleText.innerText = "不正解...";
            titleText.style.color = "var(--color-incorrect)";
        }

        document.getElementById('feedbackExplanationText').innerText = q.explanation;
        
        const nextBtn = document.getElementById('btnNextQuestion');
        if (STATE.currentQuestionIndex === STATE.questions.length - 1) {
            nextBtn.innerText = "結果発表へ ➔";
        } else {
            nextBtn.innerText = "次の問題へ ➔";
        }
    }

    function nextQuestion() {
        STATE.currentQuestionIndex++;
        if (STATE.currentQuestionIndex < STATE.questions.length) {
            switchView('quizPlayView');
            renderCurrentQuestion();
        } else {
            showResultsScreen();
        }
    }

    function showResultsScreen() {
        switchView('quizResultView');
        const total = STATE.questions.length;
        const correct = STATE.correctCount;
        const accuracy = Math.round((correct / total) * 100);
        const finalScore = correct === total ? 100 : Math.round((correct / total) * 100);

        document.getElementById('resultScore').innerText = finalScore;
        document.getElementById('resultMaxScore').innerText = 100;
        document.getElementById('resultAccuracy').innerText = accuracy;
        document.getElementById('resultCorrectCount').innerText = correct;
        document.getElementById('resultTotalQuestions').innerText = total;

        let evalMsg = "";
        if (accuracy === 100) evalMsg = "🏆 完璧です！素晴らしい！社会科マスターですね！";
        else if (accuracy >= 80) evalMsg = "🌟 優秀です！あと一息で全問正解！非常に良く理解できています。";
        else if (accuracy >= 60) evalMsg = "👍 合格点クリア！間違えた問題を復習して、さらに上を目指そう。";
        else evalMsg = "📚 もう一度、解説やクイズ設定を見直して挑戦してみましょう！";
        document.getElementById('resultEvaluationText').innerText = evalMsg;

        STATE.stats.attempts++;
        STATE.stats.totalAnswered += total;
        STATE.stats.totalCorrect += correct;
        if (finalScore > STATE.stats.highScore) STATE.stats.highScore = finalScore;
        saveStats();
    }

    function renderReviewView() {
        switchView('quizReviewView');
        const container = document.getElementById('reviewItemsContainer');
        container.innerHTML = '';

        STATE.history.forEach((hist, idx) => {
            const q = hist.questionObj;
            const card = document.createElement('div');
            card.className = 'review-card glass-panel';

            let badgeClass = 'incorrect';
            let badgeText = '不正解';
            if (hist.isTimeout) {
                badgeClass = 'timeout';
                badgeText = '時間切れ';
            } else if (hist.isCorrect) {
                badgeClass = 'correct';
                badgeText = '正解';
            }

            const userChoiceText = hist.userSelection >= 0 ? q.options[hist.userSelection] : "無回答（時間切れ）";
            const correctChoiceText = q.options[q.answer];

            card.innerHTML = `
                <div class="review-header-row">
                    <div class="review-card-meta">
                        <span class="review-num">Q${idx + 1}</span>
                        <span class="review-cat">${q.category}</span>
                    </div>
                    <span class="review-badge ${badgeClass}">${badgeText}</span>
                </div>
                <div class="review-question">${q.question}</div>
                <div class="review-answers-compare">
                    <div class="review-ans-box user-choice ${hist.isCorrect ? 'was-correct' : ''}">
                        <span class="ans-label">あなたの回答:</span>
                        <strong>${userChoiceText}</strong>
                    </div>
                    <div class="review-ans-box correct-choice">
                        <span class="ans-label">正しい正解:</span>
                        <strong>${correctChoiceText}</strong>
                    </div>
                </div>
                <div class="review-explanation-box">
                    <strong>💡 解説</strong>
                    <p>${q.explanation}</p>
                </div>
            `;
            container.appendChild(card);
        });
    }

    function startTimer() {
        const fill = document.getElementById('timerBarFill');
        if (!fill) return;

        STATE.timer.timeLeft = STATE.timer.duration;
        fill.style.width = '100%';
        fill.style.backgroundColor = 'var(--color-correct)';

        if (STATE.timer.id) clearInterval(STATE.timer.id);

        STATE.timer.id = setInterval(() => {
            STATE.timer.timeLeft -= STATE.timer.interval;
            const pct = (STATE.timer.timeLeft / STATE.timer.duration) * 100;
            fill.style.width = `${pct}%`;

            if (pct < 30) fill.style.backgroundColor = 'var(--color-incorrect)';
            else if (pct < 60) fill.style.backgroundColor = 'var(--accent)';

            if (STATE.timer.timeLeft <= 0) {
                stopTimer();
                handleTimeout();
            }
        }, STATE.timer.interval);
    }

    function stopTimer() {
        if (STATE.timer.id) {
            clearInterval(STATE.timer.id);
            STATE.timer.id = null;
        }
    }

    function setupQuizEvents() {
        const optionBtns = document.querySelectorAll('.play-option-btn');
        optionBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                const idx = parseInt(btn.getAttribute('data-index'), 10);
                selectOption(idx);
            });
        });

        document.getElementById('btnNextQuestion').addEventListener('click', nextQuestion);
        document.getElementById('btnRestartQuiz').addEventListener('click', startQuizSession);
        document.getElementById('btnGoToReview').addEventListener('click', renderReviewView);
        document.getElementById('btnBackToDashboard').addEventListener('click', () => { switchView('dashboardView'); });
        document.getElementById('btnReviewBackDashboard').addEventListener('click', () => { switchView('dashboardView'); });
    }

    function setupKeyboardSupport() {
        document.addEventListener('keydown', (e) => {
            if (STATE.view !== 'quizPlayView' || STATE.selectedOptionIndex !== null) return;
            if (e.key === '1') selectOption(0);
            else if (e.key === '2') selectOption(1);
            else if (e.key === '3') selectOption(2);
            else if (e.key === '4') selectOption(3);
        });
    }

});
